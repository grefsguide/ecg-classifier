{
  "uid": "ecg-inference-overview",
  "title": "ECG Inference Overview",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "timezone": "browser",
  "panels": [
    {
      "type": "timeseries",
      "title": "Throughput by model",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (model_name, model_key) (rate(ecg_inference_requests_total{status=\"success\"}[1m]))",
          "legendFormat": "{{model_name}} / {{model_key}}"
        }
      ],
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 8
      }
    },
    {
      "type": "timeseries",
      "title": "p95 total inference latency",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, model_name, model_key) (rate(ecg_inference_total_duration_seconds_bucket[5m])))",
          "legendFormat": "{{model_name}} / {{model_key}}"
        }
      ],
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 8
      }
    },
    {
      "type": "timeseries",
      "title": "p95 forward-only latency",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, model_name, model_key) (rate(ecg_inference_forward_duration_seconds_bucket[5m])))",
          "legendFormat": "{{model_name}} / {{model_key}}"
        }
      ],
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 12,
        "h": 8
      }
    },
    {
      "type": "timeseries",
      "title": "Queue wait p95",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, queue) (rate(ecg_inference_queue_wait_seconds_bucket[5m])))",
          "legendFormat": "{{queue}}"
        }
      ],
      "gridPos": {
        "x": 12,
        "y": 8,
        "w": 12,
        "h": 8
      }
    }
  ]
}